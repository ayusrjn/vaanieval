APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# LOCAL DEVELOPMENT: SQLite
# DATABASE_URL=sqlite:///./backend.db

# VERCEL PRODUCTION: Neon PostgreSQL (free tier at https://neon.tech)
# Example: postgresql://user:password@project-name.neon.tech/vaanieval
DATABASE_URL=

SECRET_KEY=change-me
CREDENTIAL_ENCRYPTION_KEY=

# Cron job security token (used by Vercel Cron to call /api/v1/worker/drain)
# Set a strong random value for production
CRON_SECRET=

# API endpoints
ELEVENLABS_API_BASE=https://api.elevenlabs.io
VAPI_API_BASE=https://api.vapi.ai
OPENAI_API_BASE=https://api.openai.com/v1

# Vercel deployment detection (automatically set by Vercel)
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

